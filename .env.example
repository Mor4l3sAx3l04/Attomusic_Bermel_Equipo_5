PORT=3000
DATABASE_URL=postgres://usuario:password@host:5432/database
SESSION_SECRET=cambia-esto-por-un-secreto-largo
NODE_ENV=production

# Google OAuth
GOOGLE_CLIENT_ID=tu-cliente-id-de-google
GOOGLE_CLIENT_SECRET=tu-cliente-secreto-de-google
GOOGLE_CALLBACK_URL=https://attomusic.onrender.com//auth/google/callback

# Spotify API
SPOTIFY_CLIENT_ID=tu-spotify-client-id
SPOTIFY_CLIENT_SECRET=tu-spotify-client-secret

# Google Gemini AI
GEMINI_API_KEY=tu-gemini-api-key

# NewsAPI
NEWSAPI_KEY=tu-newsapi-key

# CORS
CORS_ORIGIN=https://attomusic.onrender.com

# Correo SMTP para codigos de restablecimiento
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=tu-app-password
SMTP_FROM=AttoMusic <tu-correo@gmail.com>
